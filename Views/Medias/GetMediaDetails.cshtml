@model Models.Media

@if (Model != null)
{
    User owner = DAL.DB.Users.Get(@Model.OwnerId);
    User connected = Models.User.ConnectedUser;
    <dl>
        <dd>
            @Model.Title
        </dd>
        <dd>
            @Helper.YoutubePlayer(Model.YoutubeId)
        </dd>
        <dd class="description">
            @Model.Description
        </dd>
        <dt>
            Catégorie
        </dt>

        <dd>
            @Model.Category
        </dd>

        <dt>
            Date de publication
        </dt>

        <dd>
            @Helper.When(Model.PublishDate)
        </dd>
        <dt>
            Ajouté par :
        </dt>
        <dd>
            <div class="userItem">
                <div class="UserMediumAvatar" style="background:url(@owner.Avatar)"></div>
                <div class="ellipsis">@owner.Name</div>
            </div>
        </dd>
        @if(owner.Id == connected.Id && Model.Shared)
                {
                    <dt style="color:blue">[Partagé]</dt>
                }

    </dl>
}
